{
  "name": "Dieter - Amistr Vitrine",
  "homunType": 51,
  "baseType": 2,
  "spec": {
    "type": "selector",
    "label": "root",
    "children": [
      {
        "type": "check",
        "name": "HasOwnerCommand",
        "params": {},
        "label": "comando do dono",
        "child": { "type": "action", "name": "HandleOwnerCommand", "params": {} }
      },
      {
        "type": "check",
        "name": "ShouldFlee",
        "params": {},
        "label": "sobrevivencia (HP baixo)",
        "child": { "type": "action", "name": "Flee", "params": {} }
      },
      {
        "type": "action",
        "name": "UseCastling",
        "params": {},
        "label": "Castling: dono cercado -> troca de posicao (da base Amistr)"
      },
      {
        "type": "parallel",
        "policy": "any",
        "label": "manter buffs (defensivo + ofensivo)",
        "children": [
          { "type": "action", "name": "UseDefensiveBuff", "params": {}, "label": "Granitic Armor + Amistr Bulwark" },
          { "type": "action", "name": "UseOffensiveBuff", "params": {}, "label": "Pyroclastic + Bloodlust" }
        ]
      },
      {
        "type": "sequence",
        "label": "Engajar",
        "children": [
          {
            "type": "selector",
            "label": "Definir alvo",
            "children": [
              {
                "type": "check",
                "name": "OwnerUnderAttack",
                "params": {},
                "label": "resgatar o dono",
                "child": { "type": "action", "name": "AcquireOwnerAttacker", "params": {} }
              },
              {
                "type": "check",
                "name": "HasValidTarget",
                "params": {},
                "label": "ja tem alvo"
              },
              {
                "type": "check",
                "name": "CanEngage",
                "params": {},
                "label": "pode buscar alvo",
                "child": { "type": "action", "name": "AcquireTarget", "params": { "by": "nearest" } }
              }
            ]
          },
          {
            "type": "selector",
            "label": "combate (escolhe uma acao)",
            "children": [
              {
                "type": "cooldown",
                "ms": 12000,
                "label": "debuff de chefe a cada 12s",
                "child": {
                  "type": "monsterCheck",
                  "monster": 0,
                  "group": 2,
                  "negate": false,
                  "label": "se o alvo e CHEFE -> Volcanic Ash (cinzas)",
                  "child": {
                    "type": "action",
                    "name": "UseSkill",
                    "params": { "skill": 8043, "level": 5, "on": "enemy" }
                  }
                }
              },
              {
                "type": "action",
                "name": "UseAoESkill",
                "params": {},
                "label": "Lava Slide DoT (2+ mobs)"
              },
              {
                "type": "check",
                "name": "InAttackRange",
                "params": {},
                "label": "no alcance -> ataque normal (Dieter nao tem single)",
                "child": { "type": "action", "name": "AttackTarget", "params": {} }
              },
              {
                "type": "action",
                "name": "ChaseTarget",
                "params": { "dist": 1, "giveUp": 1500 },
                "label": "perseguir o alvo"
              }
            ]
          }
        ]
      },
      {
        "type": "selector",
        "label": "Ocioso",
        "children": [
          {
            "type": "check",
            "name": "TooFarFromOwner",
            "params": { "dist": 4 },
            "label": "longe do dono -> voltar",
            "child": { "type": "action", "name": "MoveToOwner", "params": {} }
          },
          { "type": "action", "name": "Idle", "params": {} }
        ]
      }
    ]
  }
}
